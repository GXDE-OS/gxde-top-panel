@PACKAGE_INIT@

set(GxdeTopPanel_VERSION @VERSION@)
set(GxdeTopPanel_INCLUDE_DIR "${CMAKE_CURRENT_LIST_DIR}/../../../include/gxde-top-panel")

if(NOT TARGET GxdeTopPanel::Interface)
    add_library(GxdeTopPanel::Interface INTERFACE IMPORTED)
    set_target_properties(GxdeTopPanel::Interface PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${GxdeTopPanel_INCLUDE_DIR}"
    )
endif()

check_required_components(GxdeTopPanel)
